# Ganti semua nilai ini sebelum deploy!

# Flask
SECRET_KEY=ganti_dengan_string_random_panjang

# Database (contoh PostgreSQL untuk production)
DATABASE_URL=sqlite:///recipes.db

# JWT
JWT_SECRET_KEY=ganti_dengan_string_random_panjang

# Admin seed (password akun admin pertama)
ADMIN_PASSWORD=ganti_password_admin_yang_kuat

# LLM
LLM_BASE_URL=https://delcom.org/api
LLM_TOKEN=isi_token_kamu_disini
LLM_MODEL=gpt-4o-mini

# CORS — pisahkan dengan koma jika lebih dari satu origin
# Kosongkan untuk mengizinkan semua (tidak disarankan di production)
ALLOWED_ORIGINS=https://yourdomain.com
